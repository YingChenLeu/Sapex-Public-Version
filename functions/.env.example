# Copy to .env for local testing (never commit .env).
# Production: use `firebase functions:secrets:set RESEND_API_KEY`

RESEND_API_KEY=
# Used for links and email logo: {APP_PUBLIC_URL}/simple-logo.png (see public/simple-logo.png)
APP_PUBLIC_URL=
RESEND_FROM=Sapex <noreply@sapexconnect.com>

# Needed for createStudyRoomMeet callable function.
# Provide a service account JSON string (not base64), and optionally a calendar id.
CALENDAR_CREDENTIALS_JSON=
CALENDAR_ID=primary
